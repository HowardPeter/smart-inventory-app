// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ActiveStatus {
  active
  inactive
}

enum StoreRole {
  manager
  staff
}

enum TransactionType {
  import
  export
  adjustment
}

enum TransactionStatus {
  pending
  completed
  cancelled
}

enum BarcodeType {
  upc
  ean
  code128
  qr
}

enum BarcodeStatus {
  valid
  invalid
  not_found
}

enum AuditActionType {
  create
  update
  delete
}

enum AdjustmentType {
  set
  increase
  decrease
}

model UserProfile {
  userId       String       @id @default(uuid()) @map("user_id")
  authUserId   String?      @unique @map("auth_user_id")
  email        String?
  fullName     String?      @map("full_name")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  activeStatus ActiveStatus @default(active) @map("active_status")

  storesOwned  Store[]
  transactions Transaction[]
  auditLogs    AuditLog[]
  storeMembers StoreMember[]
}

model Store {
  storeId      String       @id @default(uuid()) @map("store_id")
  address      String?
  timezone     String?
  name         String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  activeStatus ActiveStatus @default(active) @map("active_status")
  userId       String       @map("user_id")

  owner         UserProfile    @relation(fields: [userId], references: [userId])
  categories    Category[]
  products      Product[]
  auditLogs     AuditLog[]
  storeMembers  StoreMember[]
  hidedDefaults HidedDefault[]
}

model StoreMember {
  userId       String       @map("user_id")
  storeId      String       @map("store_id")
  role         StoreRole
  joinedAt     DateTime     @default(now()) @map("joined_at")
  activeStatus ActiveStatus @default(active) @map("active_status")

  user  UserProfile @relation(fields: [userId], references: [userId])
  store Store       @relation(fields: [storeId], references: [storeId])

  @@id([userId, storeId])
}

model Category {
  categoryId  String  @id @default(uuid()) @map("category_id")
  name        String
  description String?
  isDefault   Boolean @map("is_default")
  storeId     String? @map("store_id")

  store         Store?         @relation(fields: [storeId], references: [storeId])
  products      Product[]
  hidedDefaults HidedDefault[]
}

model Product {
  productId    String       @id @default(uuid()) @map("product_id")
  name         String
  imageUrl     String?      @map("image_url")
  brand        String?
  activeStatus ActiveStatus @default(active) @map("active_status")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  storeId      String       @map("store_id")
  categoryId   String       @map("category_id")

  store           Store            @relation(fields: [storeId], references: [storeId])
  category        Category         @relation(fields: [categoryId], references: [categoryId])
  productPackages ProductPackage[]
}

model Transaction {
  transactionId String            @id @default(uuid()) @map("transaction_id")
  type          TransactionType
  note          String?
  status        TransactionStatus
  createdAt     DateTime          @default(now()) @map("created_at")
  totalPrice    Decimal           @map("total_price") @db.Decimal(18, 2)
  userId        String            @map("user_id")

  user               UserProfile         @relation(fields: [userId], references: [userId])
  transactionDetails TransactionDetail[]
}

model Unit {
  unitId String @id @default(uuid()) @map("unit_id")
  code   String
  name   String

  productPackages ProductPackage[]
}

model ProductPackage {
  productPackageId String       @id @default(uuid()) @map("product_package_id")
  displayName      String?      @map("display_name")
  importPrice      Decimal?     @map("import_price") @db.Decimal(18, 2)
  sellingPrice     Decimal?     @map("selling_price") @db.Decimal(18, 2)
  activeStatus     ActiveStatus @default(active) @map("active_status")
  barcodeValue     String?      @map("barcode_value")
  barcodeType      BarcodeType? @map("barcode_type")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  unitId           String       @map("unit_id")
  productId        String       @map("product_id")

  unit               Unit                @relation(fields: [unitId], references: [unitId])
  product            Product             @relation(fields: [productId], references: [productId])
  inventory           Inventory?
  transactionDetails TransactionDetail[]
}

model Inventory {
 inventoryId      String   @id @default(uuid()) @map("inventory_id")
  quantity         Int
  reorderThreshold Int?     @map("reorder_threshold")
  lastCount        Int?     @map("last_count")
  updatedAt        DateTime @updatedAt @map("updated_at")
  activeStatus     ActiveStatus @default(active) @map("active_status")
  productPackageId String   @unique @map("product_package_id")
  productPackage   ProductPackage @relation(fields: [productPackageId], references: [productPackageId])
  adjustments      InventoryAdjustment[]
}

model InventoryAdjustment {
  inventoryAdjustmentId String         @id @default(uuid()) @map("inventory_adjustment_id")
  inventoryId           String         @map("inventory_id")
  previousQuantity      Int            @map("previous_quantity")
  currentQuantity       Int            @map("current_quantity")
  changedQuantity       Int            @map("changed_quantity")
  type                  AdjustmentType
  reason                String?
  note                  String?
  createdBy             String         @map("created_by") // Lưu userId người thao tác
  createdAt             DateTime       @default(now()) @map("created_at")
  inventory             Inventory      @relation(fields: [inventoryId], references: [inventoryId])
}

model TransactionDetail {
  quantity         Int
  unitPrice        Decimal @map("unit_price") @db.Decimal(18, 2)
  transactionId    String  @map("transaction_id")
  productPackageId String  @map("product_package_id")

  transaction    Transaction    @relation(fields: [transactionId], references: [transactionId])
  productPackage ProductPackage @relation(fields: [productPackageId], references: [productPackageId])

  @@id([transactionId, productPackageId])
}

model AuditLog {
  eventId     String           @id @default(uuid()) @map("event_id")
  actionType  AuditActionType? @map("action_type")
  entityType  String?          @map("entity_type")
  oldValue    Json?            @map("old_value")
  newValue    Json?            @map("new_value")
  performedAt DateTime         @default(now()) @map("performed_at")
  userId      String           @map("user_id")
  storeId     String           @map("store_id")

  user  UserProfile @relation(fields: [userId], references: [userId])
  store Store       @relation(fields: [storeId], references: [storeId])
}

model BarcodeApiCache {
  barcode   String        @id @unique
  payload   Json
  provider  String?
  type      BarcodeType?
  status    BarcodeStatus
  fetchedAt DateTime      @default(now()) @map("fetched_at")
}

model HidedDefault {
  storeId    String @map("store_id")
  categoryId String @map("category_id")

  store    Store    @relation(fields: [storeId], references: [storeId])
  category Category @relation(fields: [categoryId], references: [categoryId])

  @@id([storeId, categoryId])
}
